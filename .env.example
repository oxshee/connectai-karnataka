# ConnectAI Karnataka — Environment Configuration
# Copy to .env and fill in your values

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql://connectai:connectai@localhost:5432/connectai_karnataka

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://connectai.karnataka.gov.in"]

# Anthropic AI (for explainability layer)
ANTHROPIC_API_KEY=your_key_here

# Data paths
DATA_DIR=./data
MODEL_DIR=./models

# Sentinel / STAC (optional live data)
STAC_ENDPOINT=https://earth-search.aws.element84.com/v1

# Logging
LOG_LEVEL=INFO
